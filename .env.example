# Copy this to .env and fill in your credentials. Never commit .env.

# Interactive Brokers (TWS or IB Gateway must be running locally)
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=1

# Kite Connect (Zerodha) — get from kite.trade
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# Finnhub (earnings dates / surprises) — https://finnhub.io free tier (60 req/min)
FINNHUB_API_KEY=

# Alpaca — paper + live key pairs; ALPACA_MODE picks which pair to use.
# Paper keys: https://app.alpaca.markets/paper/dashboard/overview
# Live  keys: https://app.alpaca.markets/brokerage/dashboard/overview
ALPACA_MODE=paper
ALPACA_PAPER_KEY=
ALPACA_PAPER_SECRET=
ALPACA_LIVE_KEY=
ALPACA_LIVE_SECRET=

# Logging
LOG_LEVEL=INFO
