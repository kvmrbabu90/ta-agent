{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "composite": true,
    "emitDeclarationOnly": true,
    "declaration": true,
    "outDir": "./node_modules/.tmp/tsc-node"
  },
  "include": ["vite.config.ts"]
}
